{
  "name": "master-typing-pro",
  "version": "1.1.10",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:electron": "next build && electron .",
    "build:electron": "next build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.101.0",
    "@types/nodemailer": "^8.0.1",
    "@types/three": "^0.184.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-serve": "^1.3.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "nodemailer": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "firebase-tools": "^15.20.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.mastertypingpro.app",
    "productName": "Master Typing Pro",
    "icon": "public/icon.png",
    "directories": {
      "output": "dist-electron-v10"
    },
    "files": [
      "main.js",
      "out/**/*",
      "node_modules/**/*"
    ],
    "compression": "store",
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "public/installerHeader.png",
      "installerSidebar": "public/installerSidebar.png",
      "uninstallerSidebar": "public/installerSidebar.png",
      "perMachine": false
    }
  }
}
